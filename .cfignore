# Cloudflare Pages ignore file
# Excludes files that exceed the 25 MiB size limit
#
# Note: This applies to files deployed from the site/ directory
# The pre-commit hook and validation script provide additional protection

# Exclude development and build files (not needed in production)
.venv/
.git/
scripts/
*.pyc
__pycache__/
*.tmp
*.bak

# Exclude large data files that may be accidentally copied
**/*.csv
**/*.json
!index.json
# Allow index.json (required for the app)

# Backup: Exclude any remaining large summary files
# (should already be filtered out, but this is a safety net)
**/summaries/*_graph.csv
**/summaries/*_graph.json
